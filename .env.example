# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (email notifications) — optional, degrades gracefully if absent
RESEND_API_KEY=re_xxxxxxxxxxxx

# Site
NEXT_PUBLIC_SITE_URL=https://elegant-suite.com
NEXT_PUBLIC_WHATSAPP_NUMBER=923173330998

# MCP server auth — secret bearer token guarding /api/mcp (the Claude connector).
# Generate a strong random value, e.g.:  node -e "console.log('he_mcp_'+require('crypto').randomBytes(24).toString('hex'))"
# Keep it secret; anyone with this token can change room names/rates.
MCP_AUTH_TOKEN=he_mcp_replace_with_a_long_random_secret

# Password for the OAuth "Approve access" screen (/api/oauth/authorize) used
# when connecting Claude Desktop/mobile as a custom connector. Kept separate
# from MCP_AUTH_TOKEN so it's short enough to type on a phone. Pick something
# memorable but not guessable — the endpoint rate-limits repeated failures.
MCP_OWNER_PASSWORD=replace_with_a_password_you_can_type_on_mobile

# Admin (set this in Supabase Auth, not here — just reminder)
# Create an admin user in Supabase Authentication dashboard
# Then add their user_id to admin_users table
